    "errorhandler": "^1.5.2",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "lodash": "^4.18.1",
    "method-override": "^3.0.0",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "prismic-dom": "^2.2.7",
    "pug": "^3.0.4",
    "ua-parser-js": "^2.0.9"
  }
